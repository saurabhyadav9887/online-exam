<!DOCTYPE html>
<html>
<head>
<title>Student Registration</title>
</head>

<body style="font-family:Arial;text-align:center">

<h2>Student Registration</h2>

<input id="name" placeholder="Name"><br><br>
<input id="email" placeholder="Email"><br><br>
<input id="trade" placeholder="Trade"><br><br>

<button onclick="register()">Register</button>

<p id="msg"></p>

<!-- OK button initially hidden -->
<button id="okBtn" style="display:none" onclick="goNext()">OK → Login</button>

<script>

function register(){

document.getElementById("msg").innerText="Processing...";

fetch("YOUR_APPS_SCRIPT_URL",{
method:"POST",
headers:{"Content-Type":"text/plain;charset=utf-8"},
body:JSON.stringify({
name:document.getElementById("name").value,
email:document.getElementById("email").value,
trade:document.getElementById("trade").value
})
})

.then(res=>res.json())
.then(data=>{

if(data.status=="success"){

document.getElementById("msg").innerHTML =
"RollNo: " + data.rollno + "<br>Password: " + data.password;

// show OK button
document.getElementById("okBtn").style.display="block";

}else{
document.getElementById("msg").innerText="Error";
}

});

}

function goNext(){

// next page (login page)
window.location.href = "index.html";

}

</script>

</body>
</html>
